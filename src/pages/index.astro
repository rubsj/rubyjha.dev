---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import ProjectCard from '~/components/projects/ProjectCard.astro';

import { findFeaturedProjects } from '~/utils/projects';
import { findLatestPosts } from '~/utils/blog';
import PersonJsonLd from '~/components/common/PersonJsonLd.astro';

const metadata = {
  title: 'Ruby Jha',
  ignoreTitleTemplate: true,
  openGraph: {
    images: [{ url: new URL('/og/home.png', Astro.site).toString(), width: 1200, height: 630 }],
  },
};

const featuredProjects = await findFeaturedProjects();
const latestPosts = await findLatestPosts({ count: 3 });
---

<Layout metadata={metadata}>
  <!-- Hero Widget -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'View Projects →',
        href: '/projects',
      },
      {
        text: 'Read Blog →',
        href: '/blog',
      },
    ]}
  >
    <Fragment slot="title">Ruby Jha</Fragment>

    <Fragment slot="subtitle">
      <span class="block text-xl md:text-2xl font-semibold mb-2"> Engineering Manager · Generative AI · Cloud </span>
      The next decade belongs to engineering leaders who build with AI.
    </Fragment>
  </Hero>

  <!-- Elevator Pitch -->
  <section
    class="py-10 px-4 sm:px-6 bg-slate-50 dark:bg-slate-900/50 border-t border-slate-200 dark:border-slate-700/50"
  >
    <div class="max-w-[800px] mx-auto text-center leading-[1.7]">
      <p class="text-base sm:text-lg text-slate-700 dark:text-slate-300">
        I spent the last two decades leading engineering teams at State Street, Centene, and EY — building platforms
        that handle real money, real patient data, and real regulatory scrutiny. The kind of work where downtime means
        someone's claim doesn't get processed and a bad deployment means financial loss.
      </p>
      <p class="mt-5 text-base sm:text-lg text-slate-700 dark:text-slate-300">
        Now I'm applying that same engineering discipline to AI. I'm building 9 AI systems covering RAG pipelines,
        embedding fine-tuning, and multi-agent orchestration. Each one has evaluation frameworks, architecture decision
        records, and metrics I'd trust in a code review. The same standards I'd hold any production system to.
      </p>
    </div>
  </section>

  <!-- The Full Stack -->
  <section class="py-10 px-4 sm:px-6 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-center text-slate-900 dark:text-white mb-8">The Full Stack</h2>
      <div class="mb-8">
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-4">
          Leadership
        </p>
        <div class="flex flex-wrap gap-2">
          {
            [
              'People Management',
              'Hiring & Team Building',
              'Performance & Promotions',
              'Executive Communication',
              'Technical Strategy',
            ].map((skill) => (
              <span class="px-3 py-1.5 text-sm font-medium rounded-full border border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 bg-slate-50 dark:bg-slate-800">
                {skill}
              </span>
            ))
          }
        </div>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-4">Technical</p>
        <div class="flex flex-wrap gap-2">
          {
            [
              'Python',
              'Java',
              'TypeScript',
              'OpenAI API',
              'LangChain',
              'CrewAI',
              'FastAPI',
              'ChromaDB',
              'Azure',
              'Docker',
              'Kubernetes',
              'React',
              'Spring Boot',
              'Astro',
            ].map((skill) => (
              <span class="px-3 py-1.5 text-sm font-medium rounded-full border border-indigo-200 dark:border-indigo-800 text-indigo-700 dark:text-indigo-300 bg-indigo-50 dark:bg-indigo-950/50">
                {skill}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <WidgetWrapper>
    <Headline title="Featured Projects" subtitle="What I'm building" classes={{ container: 'mb-10' }} />
    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="mt-8 text-center">
      <a
        href="/projects"
        class="inline-flex items-center gap-1 text-indigo-600 dark:text-indigo-400 font-semibold hover:underline"
      >
        View all projects →
      </a>
    </div>
  </WidgetWrapper>

  <!-- Latest Blog Posts -->
  {
    latestPosts.length > 0 ? (
      <BlogLatestPosts
        title="Latest Blog Posts"
        information="Thoughts on AI engineering, architecture decisions, and lessons learned."
        count={3}
      />
    ) : (
      <WidgetWrapper>
        <Headline title="Latest Blog Posts" subtitle="Coming soon — technical deep-dives on each project." />
      </WidgetWrapper>
    )
  }

  <!-- About CTA -->
  <section class="py-8 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-base text-slate-400 dark:text-slate-500">More about my background</p>
      <div class="mt-3">
        <a
          href="/about"
          class="inline-flex items-center gap-2 text-indigo-600 dark:text-indigo-400 font-semibold hover:underline"
        >
          About →
        </a>
      </div>
    </div>
  </section>

  <PersonJsonLd />
</Layout>
