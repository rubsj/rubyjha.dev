---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import ProjectCard from '~/components/projects/ProjectCard.astro';

import { findFeaturedProjects } from '~/utils/projects';
import { findLatestPosts } from '~/utils/blog';
import PersonJsonLd from '~/components/common/PersonJsonLd.astro';

const metadata = {
  title: 'Ruby Jha',
  ignoreTitleTemplate: true,
};

const featuredProjects = await findFeaturedProjects();
const latestPosts = await findLatestPosts({ count: 3 });
---

<Layout metadata={metadata}>
  <!-- Hero Widget -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'View Projects →',
        href: '/projects',
      },
      {
        text: 'Read Blog →',
        href: '/blog',
      },
    ]}
  >
    <Fragment slot="title">Ruby Jha</Fragment>

    <Fragment slot="subtitle">
      <span class="block text-xl md:text-2xl font-semibold mb-2"> Engineering Manager · Generative AI · Cloud </span>
      I build AI systems and the teams that ship them.
    </Fragment>
  </Hero>

  <!-- Elevator Pitch -->
  <section
    class="py-10 px-4 sm:px-6 bg-slate-50 dark:bg-slate-900/50 border-t border-slate-200 dark:border-slate-700/50"
  >
    <div class="max-w-[800px] mx-auto text-center leading-[1.7]">
      <p class="text-base sm:text-lg text-slate-700 dark:text-slate-300">
        Not demos. Production-grade AI systems: RAG evaluation pipelines, contrastive embedding fine-tuning,
        LLM-as-Judge validation, and FastAPI services backed by vector search. Every project has real metrics,
        architecture decision records, and honest tradeoffs.
      </p>
      <p class="mt-5 text-base sm:text-lg text-slate-700 dark:text-slate-300">
        Before this, 20+ years building enterprise platforms and leading globally distributed engineering teams of up to
        12 across US, India, and Poland. At State Street: $250K/month in operational savings, 40+ enterprise customers,
        platform serving 7 global regions. At Centene: healthcare platform modernization covering 44M lives. At EY:
        12-engineer cross-functional org with zero CMMI Level 3 audit findings.
      </p>
      <p class="mt-10 text-base sm:text-lg font-medium text-slate-800 dark:text-slate-200">
        I build AI systems <em>and</em> the teams that ship them.
      </p>
    </div>
  </section>

  <!-- Portfolio Stats Bar -->
  <div
    class="flex flex-wrap justify-center items-center gap-x-8 gap-y-3 py-5 px-4 border-b border-slate-200 dark:border-slate-700/50 bg-slate-50 dark:bg-slate-900/50"
  >
    <span class="text-sm font-medium text-slate-600 dark:text-slate-400">
      <span class="font-mono font-bold text-slate-900 dark:text-slate-100">4/9</span> Projects Complete
    </span>
    <span class="text-slate-300 dark:text-slate-600" aria-hidden="true">&middot;</span>
    <span class="text-sm font-medium text-slate-600 dark:text-slate-400">
      <span class="font-mono font-bold text-slate-900 dark:text-slate-100">1,100+</span> Tests
    </span>
    <span class="text-slate-300 dark:text-slate-600" aria-hidden="true">&middot;</span>
    <span class="text-sm font-medium text-slate-600 dark:text-slate-400">
      <span class="font-mono font-bold text-slate-900 dark:text-slate-100">17</span> ADRs
    </span>
    <span class="text-slate-300 dark:text-slate-600" aria-hidden="true">&middot;</span>
    <span class="text-sm font-medium text-slate-600 dark:text-slate-400">
      <span class="font-mono font-bold text-slate-900 dark:text-slate-100">95%+</span> Coverage
    </span>
  </div>

  <!-- Tech Stack -->
  <Features
    title="Tech Stack"
    subtitle="Languages, frameworks, and tools I work with daily"
    columns={4}
    items={[
      { title: 'Python', icon: 'tabler:brand-python' },
      { title: 'Java', icon: 'tabler:coffee' },
      { title: 'TypeScript', icon: 'tabler:brand-typescript' },
      { title: 'OpenAI API', icon: 'tabler:brain' },
      { title: 'LangChain', icon: 'tabler:link' },
      { title: 'CrewAI', icon: 'tabler:users-group' },
      { title: 'FastAPI', icon: 'tabler:bolt' },
      { title: 'ChromaDB', icon: 'tabler:database' },
      { title: 'Docker', icon: 'tabler:brand-docker' },
      { title: 'Kubernetes', icon: 'tabler:topology-star' },
      { title: 'React', icon: 'tabler:brand-react' },
      { title: 'Spring Boot', icon: 'tabler:leaf' },
      { title: 'Astro', icon: 'tabler:rocket' },
    ]}
  />

  <!-- Featured Projects -->
  <WidgetWrapper>
    <Headline
      title="Featured Projects"
      subtitle="Highlights from 9 production-grade AI systems"
      classes={{ container: 'mb-10' }}
    />
    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="mt-8 text-center">
      <a
        href="/projects"
        class="inline-flex items-center gap-1 text-indigo-600 dark:text-indigo-400 font-semibold hover:underline"
      >
        View all projects →
      </a>
    </div>
  </WidgetWrapper>

  <!-- Latest Blog Posts -->
  {
    latestPosts.length > 0 ? (
      <BlogLatestPosts
        title="Latest Blog Posts"
        information="Thoughts on AI engineering, architecture decisions, and lessons learned."
        count={3}
      />
    ) : (
      <WidgetWrapper>
        <Headline title="Latest Blog Posts" subtitle="Coming soon — technical deep-dives on each project." />
      </WidgetWrapper>
    )
  }

  <!-- About CTA -->
  <section class="py-8 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-base text-slate-400 dark:text-slate-500">Want the full story?</p>
      <div class="mt-3">
        <a
          href="/about"
          class="inline-flex items-center gap-2 text-indigo-600 dark:text-indigo-400 font-semibold hover:underline"
        >
          Read my About page →
        </a>
      </div>
    </div>
  </section>

  <PersonJsonLd />
</Layout>
