---
import Layout from '~/layouts/PageLayout.astro';
import { getHomePermalink, getPermalink, getBlogPermalink } from '~/utils/permalinks';

const metadata = { title: 'Page Not Found' };
---

<Layout metadata={metadata}>
  <section class="flex items-center py-24 px-4 sm:px-6">
    <div class="max-w-md mx-auto text-center">
      <h1 class="mb-4 font-bold text-9xl">
        <span class="sr-only">Error</span>
        <span class="text-primary">404</span>
      </h1>
      <p class="text-2xl font-semibold text-slate-900 dark:text-white mb-3">Page not found</p>
      <p class="text-lg text-slate-500 dark:text-slate-400 mb-8">This page doesn't exist — but these might help:</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={getHomePermalink()} class="btn btn-primary">Home</a>
        <a href={getPermalink('/projects')} class="btn">Projects</a>
        <a href={getBlogPermalink()} class="btn">Blog</a>
        <a href={getPermalink('/about')} class="btn">About</a>
      </div>
    </div>
  </section>
</Layout>
