---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CareerTimeline from '~/components/CareerTimeline.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About',
  description:
    'Engineering Manager and AI Systems Builder with 20+ years of enterprise experience. Building production-grade AI systems while leading global engineering teams.',
};
---

<Layout metadata={metadata}>
  <!-- Page Header -->
  <section
    class="py-12 md:py-16 px-4 sm:px-6 bg-gradient-to-b from-indigo-50/50 to-transparent dark:from-indigo-950/20 dark:to-transparent"
  >
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600 dark:text-indigo-400 mb-3">About Me</p>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4">Ruby Jha</h1>
      <p class="text-xl md:text-2xl text-slate-600 dark:text-slate-300 font-medium">
        Engineering Manager | AI Systems Builder
      </p>
      <p class="mt-4 text-lg text-slate-500 dark:text-slate-400 max-w-2xl mx-auto">
        I build AI systems and the teams that ship them.
      </p>
    </div>
  </section>

  <!-- Professional Narrative -->
  <section class="py-10 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto">
      <div class="prose prose-lg dark:prose-invert max-w-none space-y-6 text-slate-700 dark:text-slate-300">
        <p>
          I'm an Engineering Manager who still writes code. With 20+ years building enterprise platforms across
          Financial Services and Healthcare, I'm now doing something different: building production-grade AI systems
          while continuing to lead engineering teams. I sit at the intersection of traditional engineering leadership
          and applied AI — and that's exactly where I want to be.
        </p>
        <p>
          My track record speaks in numbers. At State Street, I owned platform strategy for a Self-Service Portal
          serving 40+ enterprise customers across 7 global regions — US, Canada, UK, EMEA, Australia, Singapore, and
          Japan. That work drove $250K/month in sustained operational cost savings and a 60% reduction in support
          demand. At Centene, I led modernization of a healthcare platform covering approximately 44 million lives. At
          EY, I managed a 12-engineer cross-functional organization spanning US, India, and Poland with zero
          non-compliance findings across CMMI Level 3 audits.
        </p>
        <p>
          In 2025, I made a deliberate pivot: instead of just managing teams that build AI systems, I started building
          them myself. I'm now working through a portfolio of 9 production-grade AI projects spanning the full applied
          AI stack — synthetic data generation, RAG evaluation frameworks, LLM fine-tuning pipelines, multi-agent
          orchestration with CrewAI, and production RAG pipelines with Cohere reranking. The stack: Python, OpenAI,
          LangChain, ChromaDB, RAGAS, Braintrust, FastAPI. I'm not a tourist in AI. I'm a practitioner building real
          systems with real evaluation metrics.
        </p>
        <p>
          I'm looking for my next role as an Engineering Manager or AI Engineering Leader at a company pushing the
          frontier of applied AI. What I bring is rare: enterprise engineering credibility earned in regulated,
          high-stakes environments combined with hands-on capability to architect and build AI systems from scratch.
          I've led global teams through complex platform modernizations, and I'm now building the AI literacy to lead
          teams doing the same with LLMs and agents.
        </p>
      </div>
    </div>
  </section>

  <!-- Career Timeline -->
  <section class="py-10 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-8">Career Timeline</h2>
      <CareerTimeline />
    </div>
  </section>

  <!-- Current Focus Areas -->
  <Features2
    title="Current Focus Areas"
    tagline="What I'm Building"
    columns={2}
    items={[
      {
        title: 'Applied AI Systems',
        description:
          'Building 9 production-grade AI projects: RAG pipelines with evaluation frameworks, LLM fine-tuning with Braintrust, multi-agent orchestration with CrewAI, and synthetic data generation. Every project has real metrics, real architecture decisions, and honest tradeoffs.',
        icon: 'tabler:brain',
      },
      {
        title: 'Engineering Leadership',
        description:
          'Engineering Manager with 7+ years of direct people management. Scaled global teams across US, India, and Poland. Delivered platform transformations in Banking, Healthcare, and Financial Services. Now bridging traditional engineering leadership with applied AI.',
        icon: 'tabler:users',
      },
    ]}
  />

  <!-- Contact & Resume -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Download Resume',
        href: '/Ruby_Jha_Resume.pdf',
        target: '_blank',
        icon: 'tabler:download',
      },
      {
        variant: 'secondary',
        text: 'LinkedIn',
        href: 'https://linkedin.com/in/jharuby',
        target: '_blank',
        icon: 'tabler:brand-linkedin',
      },
    ]}
  >
    <Fragment slot="title">Get in Touch</Fragment>
    <Fragment slot="subtitle">
      Open to Engineering Manager and AI Engineering Leader roles. Reach me at{' '}
      <a href="mailto:rubyjha.jnv@gmail.com" class="text-primary hover:underline">rubyjha.jnv@gmail.com</a>
      {' '}or find me on{' '}
      <a href="https://github.com/rubsj" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline"
        >GitHub</a
      >.
    </Fragment>
  </CallToAction>
</Layout>
