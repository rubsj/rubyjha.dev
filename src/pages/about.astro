---
import CallToAction from '~/components/widgets/CallToAction.astro';
import CareerTimeline from '~/components/CareerTimeline.astro';
import Layout from '~/layouts/PageLayout.astro';
import PersonJsonLd from '~/components/common/PersonJsonLd.astro';

const metadata = {
  title: 'About',
  description:
    'Engineering Manager with 20+ years in enterprise platforms. Now building 9 production AI systems covering RAG, fine-tuning, and multi-agent orchestration.',
  openGraph: {
    images: [{ url: new URL('/og/about.png', Astro.site).toString(), width: 1200, height: 630 }],
  },
};
---

<Layout metadata={metadata}>
  <!-- Page Header -->
  <section
    class="py-12 md:py-16 px-4 sm:px-6 bg-gradient-to-b from-indigo-50/50 to-transparent dark:from-indigo-950/20 dark:to-transparent"
  >
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600 dark:text-indigo-400 mb-3">About Me</p>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4">Ruby Jha</h1>
      <p class="text-xl md:text-2xl text-slate-600 dark:text-slate-300 font-medium">
        Engineering Manager. Building production AI systems.
      </p>
    </div>
  </section>

  <!-- Professional Narrative -->
  <section class="py-10 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto">
      <div class="prose prose-lg dark:prose-invert max-w-none space-y-6 text-slate-700 dark:text-slate-300">
        <p>
          I have spent 20 years building enterprise platforms in Financial Services and Healthcare. Led teams, shipped
          systems, dealt with the kind of regulatory scrutiny where mistakes cost real money. Now I am building AI
          systems myself, not just managing teams that do.
        </p>
        <p>
          At State Street, I own platform strategy for a Self-Service Portal used by 40+ enterprise customers across 7
          global regions. That platform cut operational costs by $250K per month and reduced support volume by 60%.
          Before that, I led modernization of a healthcare platform at Centene covering 44 million lives. At EY, I ran
          a 12-engineer org across the US, India, and Poland with zero compliance findings in CMMI Level 3 audits.
        </p>
        <p>
          In 2025, I started building AI systems alongside my day job. Not courses or tutorials. Actual systems. I am
          working through 9 projects that cover the full applied AI stack: synthetic data generation, RAG evaluation,
          LLM fine-tuning, multi-agent orchestration, and production RAG pipelines. Python, OpenAI, LangChain, CrewAI,
          ChromaDB, FastAPI. Each project has evaluation metrics, architecture decision records, and documented
          tradeoffs.
        </p>
        <p>
          I am looking for an Engineering Manager or AI Engineering Leader role at a company doing serious work in
          applied AI. I have led global teams through complex platform builds in regulated environments. Now I am
          adding hands-on AI depth to that foundation. If you are hiring for someone who can both lead engineering
          teams and build AI systems, let's talk.
        </p>
      </div>
    </div>
  </section>

  <!-- Career Timeline -->
  <section class="py-10 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-8">Career Timeline</h2>
      <CareerTimeline />
    </div>
  </section>

  <!-- Contact & Resume -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Download Resume',
        href: '/Ruby_Jha_Resume.pdf',
        target: '_blank',
        icon: 'tabler:download',
      },
      {
        variant: 'secondary',
        text: 'LinkedIn',
        href: 'https://linkedin.com/in/jharuby',
        target: '_blank',
        icon: 'tabler:brand-linkedin',
      },
    ]}
  >
    <Fragment slot="title">Best way to reach me</Fragment>
    <Fragment slot="subtitle">
      <a href="mailto:rubyjha.jnv@gmail.com" class="text-primary dark:text-indigo-400 hover:underline"
        >rubyjha.jnv@gmail.com</a
      >
      {' '}·{' '}
      <a
        href="https://github.com/rubsj"
        target="_blank"
        rel="noopener noreferrer"
        class="text-primary dark:text-indigo-400 hover:underline">GitHub</a
      >
    </Fragment>
  </CallToAction>
  <PersonJsonLd />
</Layout>
