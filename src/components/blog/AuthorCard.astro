---
import { Icon } from 'astro-icon/components';

export interface Props {
  name?: string;
  class?: string;
}

const { name = 'Ruby Jha', class: className = '' } = Astro.props;
---

<div class:list={['max-w-3xl mx-auto px-6 sm:px-6 mt-8', className]}>
  <div
    class="border border-slate-200 dark:border-slate-700 rounded-lg p-6 flex flex-col sm:flex-row items-center sm:items-start gap-4"
  >
    <div class="flex-shrink-0">
      <div class="w-16 h-16 rounded-full bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center">
        <span class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">RJ</span>
      </div>
    </div>
    <div class="text-center sm:text-left">
      <p class="text-lg font-semibold text-slate-900 dark:text-white">{name}</p>
      <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
        Engineering Manager & AI Systems Builder. 20+ years in Financial Services and Healthcare. Building 9
        production-grade AI systems.
      </p>
      <div class="flex items-center justify-center sm:justify-start gap-3 mt-3">
        <a
          href="https://linkedin.com/in/jharuby"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400"
          aria-label="LinkedIn profile"
        >
          <Icon name="tabler:brand-linkedin" class="w-5 h-5" />
        </a>
        <a
          href="https://github.com/rubsj"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400"
          aria-label="GitHub profile"
        >
          <Icon name="tabler:brand-github" class="w-5 h-5" />
        </a>
      </div>
    </div>
  </div>
</div>
