---
interface TimelineStop {
  company: string;
  role: string;
  years: string;
  oneliner: string;
}

const timeline: TimelineStop[] = [
  {
    company: 'AI Portfolio',
    role: 'Builder',
    years: '2025–Present',
    oneliner: '9 production-grade AI systems',
  },
  {
    company: 'State Street',
    role: 'Engineering Manager',
    years: '2019–Present',
    oneliner: '$250K/mo savings, 40+ enterprise customers',
  },
  {
    company: 'Centene',
    role: 'Technical Lead',
    years: '2016–2019',
    oneliner: 'Healthcare platform modernization, 44M lives',
  },
  {
    company: 'EY',
    role: 'Engineering Manager',
    years: '2012–2015',
    oneliner: '12-engineer global org, CMMI Level 3 compliance',
  },
  {
    company: 'Sapient',
    role: 'Senior Consultant',
    years: '2010–2012',
    oneliner: 'Client-facing delivery for financial services',
  },
  {
    company: 'HSBC',
    role: 'Team Lead',
    years: '2004–2010',
    oneliner: 'Enterprise banking platforms, CIO Award recipient',
  },
];

interface Props {
  id?: string;
  classes?: Record<string, string>;
}

const { id, classes = {} } = Astro.props;
---

<div id={id} class:list={['py-4', classes?.container]}>
  <div class="relative">
    <!-- Vertical connecting line -->
    <div class="absolute left-5 top-5 bottom-5 w-0.5 bg-indigo-200 dark:bg-indigo-800" aria-hidden="true"></div>

    <!-- Timeline stops -->
    <div class="space-y-6">
      {
        timeline.map((stop) => (
          <div class="relative flex gap-5 items-start">
            <div class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full bg-white dark:bg-slate-900 border-2 border-indigo-500 flex items-center justify-center shadow-sm">
              <div class="w-2.5 h-2.5 rounded-full bg-indigo-500" />
            </div>
            <div class="flex-1 min-w-0 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 px-4 py-3 shadow-sm hover:shadow-md transition-shadow duration-200">
              <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1 mb-1">
                <h3 class="text-base font-bold text-slate-900 dark:text-white">{stop.company}</h3>
                <span class="text-xs font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 px-2 py-0.5 rounded whitespace-nowrap">
                  {stop.years}
                </span>
              </div>
              <p class="text-sm font-semibold text-slate-500 dark:text-slate-400 mb-1">{stop.role}</p>
              <p class="text-sm text-slate-600 dark:text-slate-300">{stop.oneliner}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>
