---
import { Icon } from 'astro-icon/components';
import type { Project } from '~/types';

export interface Props {
  project: Project;
}

const { project } = Astro.props;

const statusConfig = {
  completed: { label: 'Completed', classes: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400' },
  'in-progress': {
    label: 'In Progress',
    classes: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',
  },
  planned: { label: 'Planned', classes: 'bg-gray-100 text-gray-700 dark:bg-gray-700/40 dark:text-gray-400' },
};

const demoIconMap = {
  streamlit: 'tabler:browser',
  loom: 'tabler:video',
  github: 'tabler:brand-github',
  none: null,
};

const status = statusConfig[project.status];
const demoIcon = demoIconMap[project.demoType];
const visibleTechStack = project.techStack.slice(0, 5);
---

<article
  class="group relative flex flex-col rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 shadow-sm transition-all duration-200 hover:shadow-md hover:-translate-y-0.5 overflow-hidden"
>
  <a href={`/projects/${project.slug}`} class="absolute inset-0 z-10" aria-label={project.title}></a>

  <div class="flex flex-col flex-1 p-5">
    <!-- Header: number + status + demo icon -->
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-mono text-gray-400 dark:text-slate-500">
        Project {String(project.projectNumber).padStart(2, '0')}
      </span>
      <div class="flex items-center gap-2">
        {
          demoIcon && (
            <Icon
              name={demoIcon}
              class="h-4 w-4 text-gray-400 dark:text-slate-500"
              title={`Demo: ${project.demoType}`}
            />
          )
        }
        <span class={`inline-block rounded-full px-2 py-0.5 text-xs font-semibold ${status.classes}`}>
          {status.label}
        </span>
      </div>
    </div>

    <!-- Title -->
    <h3
      class="text-lg font-bold font-heading leading-tight text-slate-900 dark:text-white mb-2 group-hover:text-primary dark:group-hover:text-blue-400 transition-colors"
    >
      {project.title}
    </h3>

    <!-- Description -->
    <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed line-clamp-2 flex-1 mb-4">
      {project.description}
    </p>

    <!-- Tech stack pills -->
    <div class="flex flex-wrap gap-1">
      {
        visibleTechStack.map((tech) => (
          <span class="rounded bg-gray-100 dark:bg-slate-700 px-2 py-0.5 text-xs font-medium text-gray-600 dark:text-slate-300">
            {tech}
          </span>
        ))
      }
      {
        project.techStack.length > 5 && (
          <span class="rounded bg-gray-100 dark:bg-slate-700 px-2 py-0.5 text-xs font-medium text-gray-500 dark:text-slate-400">
            +{project.techStack.length - 5}
          </span>
        )
      }
    </div>
  </div>
</article>
