---
/**
 * RAG Evaluation Pipeline diagram — static HTML/CSS/Tailwind.
 * Replaces the Mermaid flowchart LR that Dagre renders as a squished
 * horizontal strip at blog column width (11 nodes, single row).
 *
 * Layout: two labeled phases (Build Indexes / Evaluate Configs) as
 * vertical steppers, separated by a "56 QA Pairs" bridge node.
 */
---

<div class="not-prose my-8 mx-auto max-w-md font-sans text-sm">

  <!-- ── Phase label: Build ──────────────────────────────────────── -->
  <p class="mb-2 text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500">
    Phase 1 — Build Indexes
  </p>

  <div class="flex flex-col">
    <!-- 3 Markdown Docs -->
    <div class="rounded-lg border border-slate-300 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 px-4 py-2.5">
      <span class="font-semibold text-slate-800 dark:text-slate-100">3 Markdown Docs</span>
    </div>

    <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>

    <!-- 5 Chunking Strategies -->
    <div class="rounded-lg border border-slate-300 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 px-4 py-2.5 flex items-center justify-between">
      <span class="font-semibold text-slate-800 dark:text-slate-100">5 Chunking Strategies</span>
      <span class="text-xs text-slate-500 dark:text-slate-400">fixed · semantic · ...</span>
    </div>

    <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>

    <!-- 3 Embedding Models + BM25 side-by-side -->
    <div class="grid grid-cols-2 gap-2">
      <div class="rounded-lg border border-indigo-300 dark:border-indigo-600 bg-indigo-50 dark:bg-indigo-950 px-3 py-2.5">
        <span class="font-semibold text-indigo-900 dark:text-indigo-100">3 Embedding Models</span>
        <p class="mt-0.5 text-xs text-indigo-600 dark:text-indigo-400">OpenAI · MPnet · MiniLM</p>
      </div>
      <div class="rounded-lg border border-slate-300 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 px-3 py-2.5">
        <span class="font-semibold text-slate-800 dark:text-slate-100">BM25 Baseline</span>
        <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">keyword search</p>
      </div>
    </div>

    <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>

    <!-- FAISS Index -->
    <div class="rounded-lg border border-indigo-300 dark:border-indigo-600 bg-indigo-50 dark:bg-indigo-950 px-4 py-2.5 flex items-center justify-between">
      <span class="font-semibold text-indigo-900 dark:text-indigo-100">16 FAISS Indexes</span>
      <span class="text-xs text-indigo-600 dark:text-indigo-400">one per config</span>
    </div>
  </div>

  <!-- ── Bridge: 56 QA Pairs ─────────────────────────────────────── -->
  <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>
  <div class="rounded-lg border-2 border-amber-400 dark:border-amber-500 bg-amber-50 dark:bg-amber-950 px-4 py-2.5 flex items-center justify-between">
    <span class="font-semibold text-amber-900 dark:text-amber-100">56 Synthetic QA Pairs</span>
    <span class="text-xs text-amber-700 dark:text-amber-400">same set for all configs</span>
  </div>
  <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>

  <!-- ── Phase label: Evaluate ───────────────────────────────────── -->
  <p class="mb-2 text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500">
    Phase 2 — Evaluate Configs
  </p>

  <div class="flex flex-col">
    <!-- Retrieval Metrics -->
    <div class="rounded-lg border border-slate-300 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 px-4 py-2.5 flex items-center justify-between">
      <span class="font-semibold text-slate-800 dark:text-slate-100">Retrieval Metrics</span>
      <span class="text-xs text-slate-500 dark:text-slate-400">Recall@5 · MRR</span>
    </div>

    <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>

    <!-- Cohere Reranking -->
    <div class="rounded-lg border border-slate-300 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 px-4 py-2.5 flex items-center justify-between">
      <span class="font-semibold text-slate-800 dark:text-slate-100">Cohere Reranking</span>
      <span class="text-xs text-slate-500 dark:text-slate-400">cross-encoder second pass</span>
    </div>

    <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>

    <!-- RAGAS Quality -->
    <div class="rounded-lg border border-slate-300 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 px-4 py-2.5 flex items-center justify-between">
      <span class="font-semibold text-slate-800 dark:text-slate-100">RAGAS Quality</span>
      <span class="text-xs text-slate-500 dark:text-slate-400">faithfulness · relevancy</span>
    </div>

    <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>

    <!-- LLM Judge -->
    <div class="rounded-lg border border-slate-300 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 px-4 py-2.5 flex items-center justify-between">
      <span class="font-semibold text-slate-800 dark:text-slate-100">LLM Judge</span>
      <span class="text-xs text-slate-500 dark:text-slate-400">hallucination check</span>
    </div>

    <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>

    <!-- Braintrust -->
    <div class="rounded-lg border-2 border-indigo-400 dark:border-indigo-500 bg-indigo-50 dark:bg-indigo-950 px-4 py-2.5 flex items-center justify-between">
      <span class="font-semibold text-indigo-900 dark:text-indigo-100">Braintrust</span>
      <span class="text-xs text-indigo-600 dark:text-indigo-400">all 16 runs logged</span>
    </div>
  </div>

</div>
