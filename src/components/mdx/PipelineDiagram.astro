---
/**
 * Synthetic data pipeline diagram — static HTML/CSS/Tailwind.
 * Replaces the Mermaid chart that Dagre cannot lay out cleanly at blog width
 * because of feedback edges (Corrector → Templates, Corrector → Evaluator).
 *
 * Layout: vertical stepper with numbered feedback-target badges (① ②) on
 * the Templates and Evaluator boxes, matching badges on the Corrector box,
 * and a legend callout below that labels each return path.
 */
---

<div class="not-prose my-8 mx-auto max-w-md font-sans text-sm">
  <!-- ── Pipeline stages ────────────────────────────────────────── -->
  <div class="flex flex-col">

    <!-- 1. Templates — feedback target ① -->
    <div class="flex items-center gap-3 rounded-lg border-2 border-indigo-400 dark:border-indigo-500 bg-indigo-50 dark:bg-indigo-950 px-4 py-2.5">
      <span class="inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-500 text-white font-bold" style="font-size:10px">1</span>
      <span class="font-semibold text-indigo-900 dark:text-indigo-100">Templates</span>
      <span class="text-xs text-indigo-600 dark:text-indigo-400">v1 &amp; v2</span>
    </div>

    <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>

    <!-- 2. Generator -->
    <div class="rounded-lg border border-slate-300 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 px-4 py-2.5">
      <span class="font-semibold text-slate-800 dark:text-slate-100">Generator</span>
      <span class="ml-2 text-xs text-slate-500 dark:text-slate-400">GPT-4o-mini</span>
    </div>

    <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>

    <!-- 3. Validator -->
    <div class="rounded-lg border border-slate-300 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 px-4 py-2.5">
      <span class="font-semibold text-slate-800 dark:text-slate-100">Validator</span>
      <span class="ml-2 text-xs text-slate-500 dark:text-slate-400">Pydantic v2</span>
    </div>

    <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>

    <!-- 4. Evaluator — feedback target ② -->
    <div class="flex items-center gap-3 rounded-lg border-2 border-indigo-400 dark:border-indigo-500 bg-indigo-50 dark:bg-indigo-950 px-4 py-2.5">
      <span class="inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-500 text-white font-bold" style="font-size:10px">2</span>
      <span class="font-semibold text-indigo-900 dark:text-indigo-100">Evaluator</span>
      <span class="text-xs text-indigo-600 dark:text-indigo-400">GPT-4o Judge</span>
    </div>

    <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>

    <!-- 5. Failure Analysis -->
    <div class="rounded-lg border border-slate-300 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 px-4 py-2.5">
      <span class="font-semibold text-slate-800 dark:text-slate-100">Failure Analysis</span>
    </div>

    <div class="flex justify-center py-1 text-base leading-none text-slate-400 dark:text-slate-500">↓</div>

    <!-- 6. Corrector — feedback source → ① and ② -->
    <div class="flex items-center justify-between rounded-lg border-2 border-orange-400 dark:border-orange-500 bg-orange-50 dark:bg-orange-950 px-4 py-2.5">
      <span class="font-semibold text-orange-900 dark:text-orange-100">Corrector</span>
      <div class="flex items-center gap-1.5 text-orange-600 dark:text-orange-400">
        <span class="text-xs font-medium">feeds back to</span>
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-orange-500 text-white font-bold" style="font-size:10px">1</span>
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-orange-500 text-white font-bold" style="font-size:10px">2</span>
      </div>
    </div>
  </div>

  <!-- ── Feedback loop legend ────────────────────────────────────── -->
  <div class="mt-3 rounded-lg border border-dashed border-orange-300 dark:border-orange-700 bg-orange-50/60 dark:bg-orange-950/60 px-4 py-3 space-y-2">
    <p class="text-orange-700 dark:text-orange-400 font-bold uppercase tracking-wide" style="font-size:11px">↺ Feedback Loop</p>

    <div class="flex items-center gap-2 text-xs">
      <span class="inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-500 text-white font-bold" style="font-size:10px">1</span>
      <span class="text-slate-700 dark:text-slate-300">Corrector → Templates</span>
      <span class="ml-auto rounded bg-orange-200 dark:bg-orange-800/70 px-2 py-0.5 font-medium text-orange-800 dark:text-orange-200" style="font-size:11px">improved templates</span>
    </div>

    <div class="flex items-center gap-2 text-xs">
      <span class="inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-500 text-white font-bold" style="font-size:10px">2</span>
      <span class="text-slate-700 dark:text-slate-300">Corrector → Evaluator</span>
      <span class="ml-auto rounded bg-orange-200 dark:bg-orange-800/70 px-2 py-0.5 font-medium text-orange-800 dark:text-orange-200" style="font-size:11px">fixed records</span>
    </div>
  </div>
</div>
