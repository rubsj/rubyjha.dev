---
import { renderMermaidToSvg } from '~/utils/render-mermaid';

export interface Props {
  chart: string;
}

const { chart } = Astro.props;

let svg: string;
try {
  svg = await renderMermaidToSvg(chart);
} catch (err) {
  // Fallback: show the raw definition if rendering fails at build time.
  console.error('[MermaidDiagram] build-time render failed:', err);
  svg = `<pre class="text-sm text-gray-500 whitespace-pre-wrap">${chart}</pre>`;
}
---

<div
  class="my-6 overflow-x-auto rounded-lg border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-4"
>
  <Fragment set:html={svg} />
</div>
