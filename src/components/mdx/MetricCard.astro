---
export interface Props {
  label: string;
  value: string;
}

const { label, value } = Astro.props;
---

<div
  class="flex flex-col items-center justify-center rounded-lg border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-4 shadow-sm text-center"
>
  <div class="font-heading text-3xl font-bold text-primary dark:text-blue-400">
    {value}
  </div>
  <div class="mt-1 text-sm font-medium uppercase tracking-widest text-gray-500 dark:text-slate-400">
    {label}
  </div>
</div>
