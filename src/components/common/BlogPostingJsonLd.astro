---
import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
  image?: string;
}

const { post, url, image } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.excerpt || '',
  datePublished: post.publishDate.toISOString(),
  ...(post.updateDate ? { dateModified: post.updateDate.toISOString() } : {}),
  author: {
    '@type': 'Person',
    name: post.author || 'Ruby Jha',
    url: 'https://rubyjha.dev/about',
  },
  publisher: {
    '@type': 'Person',
    name: 'Ruby Jha',
    url: 'https://rubyjha.dev',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': String(url),
  },
  ...(image ? { image } : {}),
  ...(post.tags?.length ? { keywords: post.tags.map((t) => t.title).join(', ') } : {}),
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
